{
  "name": "fantasy-ai",
  "version": "1.0.0",
  "description": "AI TRPG Fantasy Text Game",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon --exec ts-node --project tsconfig.server.json server/index.ts",
    "client": "vite",
    "build": "vite build",
    "vercel-build": "vite build",
    "build:server": "tsc --project tsconfig.server.json",
    "build:all": "npm run build && npm run build:server",
    "start": "node dist/server/server/index.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.1.62",
    "@anthropic-ai/sdk": "^0.78.0",
    "@fal-ai/client": "^1.2.0",
    "axios": "^1.7.9",
    "claude": "^0.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "fs-extra": "^11.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^9.0.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.0",
    "nodemon": "^3.1.9",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
